{
  "name": "@neo-angband/cli",
  "version": "0.1.0",
  "private": true,
  "description": "Terminal front-end and developer harness (headless runs, stats, golden scenarios)",
  "license": "GPL-2.0-only",
  "author": "neostryder (RPGM Tools)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "stats": "node --import ./register.mjs dist/main-stats.js",
    "stats:baseline": "node --import ./register.mjs dist/main-baseline.js",
    "c:import": "node --import ./register.mjs dist/main-cimport.js",
    "c:parity": "node --import ./register.mjs dist/main-cparity.js",
    "scenarios": "node --import ./register.mjs dist/main-scenarios.js",
    "spoil": "node --import ./register.mjs dist/main-spoil.js"
  },
  "dependencies": {
    "@neo-angband/core": "workspace:*"
  }
}
